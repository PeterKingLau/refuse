{
  "name": "refuse-classification-system",
  "version": "2.0.1",
  "description": "智能垃圾分类管理系统",
  "private": true,
  "scripts": {
    "i": "pnpm install",
    "dev": "vite --mode base",
    "ts:check": "vue-tsc --noEmit",
    "build:pro": "vite build --mode pro",
    "build:pro:ip": "pnpm run ts:check && vite build --mode pro-ip",
    "build:pro:hxd": "pnpm run ts:check && vite build --mode pro-hxd",
    "build:dev": "pnpm run ts:check && vite build --mode dev",
    "build:test": "pnpm run ts:check && vite build --mode test",
    "serve:pro": "vite preview --mode pro",
    "serve:dev": "vite preview --mode dev",
    "serve:test": "vite preview --mode test",
    "deps:check": "pnpm dlx npm-check-updates",
    "clean": "rimraf node_modules",
    "clean:cache": "rimraf node_modules/.cache",
    "lint:eslint": "eslint \"src/**/*.{js,ts,tsx,vue}\" --fix",
    "lint:format": "prettier --write --log-level warn \"src/**/*.{js,ts,json,tsx,css,less,vue,html,md}\"",
    "lint:style": "stylelint --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:lint-staged": "lint-staged -c ./.husky/lintstagedrc.js",
    "prepare": "husky",
    "analysis": "windicss-analysis"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@antv/g2": "^5.4.8",
    "@uppy/xhr-upload": "^2.1.3",
    "@videojs/http-streaming": "^3.17.4",
    "@vueuse/core": "^14.3.0",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/vue-3": "^3.23.6",
    "@zxcvbn-ts/core": "^3.0.4",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.16.1",
    "iconify-icon": "^3.0.2",
    "intro.js": "^8.3.2",
    "lodash-es": "^4.18.1",
    "emittery": "^1.2.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "qs": "^6.15.2",
    "tslib": "^2.8.1",
    "url": "^0.11.4",
    "video.js": "^8.23.7",
    "videojs-contrib-hls": "^5.15.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vue-types": "^6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@types/intro.js": "^5.1.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-less": "^6.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "unplugin-vue-macros": "^2.14.5",
    "vite": "^6.4.2",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-windicss": "^1.9.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "2.1.10",
    "windicss": "^3.5.6",
    "windicss-analysis": "^0.3.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "homepage": ""
}
